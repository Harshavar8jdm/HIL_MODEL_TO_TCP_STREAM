#define BLAST_SIZE 1460
#define ALLOCATED_SAMPLES 1000000
#define BYTES_TO_TRANSFER  (ALLOCATED_SAMPLES * 4)
#define BLAST_SIZE 1460 // Standard Ethernet TCP Maximum Segment Size (MSS)
extern XAxiDma dma_instance;
struct tcp_pcb *active_pcb = NULL; // Tracks our PC client
extern uint32_t destination_buffer[];
extern XAxiDma dma_instance;

// State Machine Definitions
typedef enum {
    SYS_IDLE = 0,
    SYS_START_DMA,
    SYS_WAIT_DMA,
    SYS_STREAM_TCP
} sys_state_t;


int transfer_data() {
    if (active_pcb == NULL) {
        return 0;
    }

    static sys_state_t current_state = SYS_IDLE;
    static int tx_bytes_offset = 0;
    int status;

    switch (current_state) {

        case SYS_IDLE:
            tx_bytes_offset = 0;
            current_state = SYS_START_DMA;
            break;

        case SYS_START_DMA:
            tx_bytes_offset = 0;

            status = XAxiDma_SimpleTransfer(&dma_instance, (UINTPTR)destination_buffer,
                                            BYTES_TO_TRANSFER, XAXIDMA_DEVICE_TO_DMA);
            if (status == XST_SUCCESS) {
                current_state = SYS_WAIT_DMA;
            }
            break;

        case SYS_WAIT_DMA:

            if (!XAxiDma_Busy(&dma_instance, XAXIDMA_DEVICE_TO_DMA)) {

                Xil_DCacheInvalidateRange((UINTPTR)destination_buffer, BYTES_TO_TRANSFER);

                tx_bytes_offset = 0;
                current_state = SYS_STREAM_TCP;
            }
            break;

        case SYS_STREAM_TCP: {
            int remaining_bytes = BYTES_TO_TRANSFER - tx_bytes_offset;

            if (remaining_bytes <= 0) {
                current_state = SYS_START_DMA;
                break;
            }

            int available_tcp_space = tcp_sndbuf(active_pcb);
            int chunk_size = (remaining_bytes < available_tcp_space) ? remaining_bytes : available_tcp_space;

            if (chunk_size > 0) {

                uint8_t *data_payload_ptr = (uint8_t *)destination_buffer + tx_bytes_offset;


                err_t err = tcp_write(active_pcb, data_payload_ptr, chunk_size, TCP_WRITE_FLAG_COPY);
                if (err == ERR_OK) {
                    tcp_output(active_pcb); // Push onto physical link immediately
                    tx_bytes_offset += chunk_size;
                }
            }


        case SYS_STREAM_TCP: {
            int remaining_bytes = BYTES_TO_TRANSFER - tx_bytes_offset;


            if (remaining_bytes <= 0) {

                current_state = SYS_START_DMA;
                break;
            }

            int available_tcp_space = tcp_sndbuf(active_pcb);
            int chunk_size = (remaining_bytes < available_tcp_space) ? remaining_bytes : available_tcp_space;

            if (chunk_size > 0) {
                uint8_t *data_payload_ptr = (uint8_t *)destination_buffer + tx_bytes_offset;

                err_t err = tcp_write(active_pcb, data_payload_ptr, chunk_size, TCP_WRITE_FLAG_COPY);
                if (err == ERR_OK) {
                    tcp_output(active_pcb);
                    tx_bytes_offset += chunk_size;
                }
            }
            break;
        }
    }

    return 0;
}


void print_app_header()
{
#if (LWIP_IPV6==0)
	xil_printf("\n\r\n\r-----lwIP TCP echo server ------\n\r");
#else
	xil_printf("\n\r\n\r-----lwIPv6 TCP echo server ------\n\r");
#endif
	xil_printf("TCP packets sent to port 6001 will be echoed back\n\r");
}

err_t recv_callback(void *arg, struct tcp_pcb *tpcb,
                               struct pbuf *p, err_t err)
{
	/* do not read the packet if we are not in ESTABLISHED state */
	if (!p) {
		active_pcb = NULL;
		tcp_close(tpcb);
		tcp_recv(tpcb, NULL);
		return ERR_OK;
	}

	/* indicate that the packet has been received */
	tcp_recved(tpcb, p->len);

	/* echo back the payload */
	/* in this case, we assume that the payload is < TCP_SND_BUF */
	if (tcp_sndbuf(tpcb) > p->len) {
		err = tcp_write(tpcb, p->payload, p->len, 1);
	} else
		xil_printf("no space in tcp_sndbuf\n\r");

	/* free the received pbuf */
	pbuf_free(p);

	return ERR_OK;
}

err_t accept_callback(void *arg, struct tcp_pcb *newpcb, err_t err)
{
	static int connection = 1;

	/* set the receive callback for this connection */
	tcp_recv(newpcb, recv_callback);

	/* just use an integer number indicating the connection id as the
	   callback argument */
	tcp_arg(newpcb, (void*)(UINTPTR)connection);

	/* increment for subsequent accepted connections */
	connection++;

	active_pcb = newpcb;

	// changed from original
	// Disable Nagle's algorithm to force small 1024-byte frames out instantly
	tcp_nagle_disable(newpcb);

	return ERR_OK;
}


int start_application()
{
	struct tcp_pcb *pcb;
	err_t err;
	unsigned port = 7;

	/* create new TCP PCB structure */
	pcb = tcp_new_ip_type(IPADDR_TYPE_ANY);
	if (!pcb) {
		xil_printf("Error creating PCB. Out of Memory\n\r");
		return -1;
	}

	/* bind to specified @port */
	err = tcp_bind(pcb, IP_ANY_TYPE, port);
	if (err != ERR_OK) {
		xil_printf("Unable to bind to port %d: err = %d\n\r", port, err);
		return -2;
	}

	/* we do not need any arguments to callback functions */
	tcp_arg(pcb, NULL);

	/* listen for connections */
	pcb = tcp_listen(pcb);
	if (!pcb) {
		xil_printf("Out of memory while tcp_listen\n\r");
		return -3;
	}

	/* specify callback to use for incoming connections */
	tcp_accept(pcb, accept_callback);

	xil_printf("TCP echo server started @ port %d\n\r", port);

	return 0;
}
