int transfer_data() {
    // If no client is connected to our GUI/PC script, reset state and wait
    if (active_pcb == NULL) {
        return 0;
    }

    static sys_state_t current_state = SYS_IDLE;
    static int tx_bytes_offset = 0;
    int status;

    switch (current_state) {

        case SYS_IDLE:
            tx_bytes_offset = 0;
            current_state = SYS_START_DMA;
            break;

        case SYS_START_DMA:
            tx_bytes_offset = 0;

            // 1. Kick off the Simple DMA Transfer (Non-blocking call)
            // Removed cache invalidation from here—doing it before the transfer opens a race window.
            status = XAxiDma_SimpleTransfer(&dma_instance, (UINTPTR)destination_buffer,
                                            BYTES_TO_TRANSFER, XAXIDMA_DEVICE_TO_DMA);
            if (status == XST_SUCCESS) {
                current_state = SYS_WAIT_DMA;
            }
            break;

        case SYS_WAIT_DMA:
            // 2. Poll the hardware registers non-blockingly.
            if (!XAxiDma_Busy(&dma_instance, XAXIDMA_DEVICE_TO_DMA)) {

                // CRITICAL FIX: Invalidate cache AFTER the hardware finishes writing to DDR.
                // This forces the ARM CPU to pull the fresh data directly out of physical memory.
                Xil_DCacheInvalidateRange((UINTPTR)destination_buffer, BYTES_TO_TRANSFER);

                tx_bytes_offset = 0;
                current_state = SYS_STREAM_TCP;
            }
            break;
            /*
        case SYS_STREAM_TCP: {
            int remaining_bytes = BYTES_TO_TRANSFER - tx_bytes_offset;

            // If the entire 40,960-byte block has been streamed, loop back for fresh samples
            if (remaining_bytes <= 0) {
                current_state = SYS_START_DMA;
                break;
            }

            // 3. Check available room in the lwIP TCP transmit window buffer
            int available_tcp_space = tcp_sndbuf(active_pcb);
            int chunk_size = (remaining_bytes < available_tcp_space) ? remaining_bytes : available_tcp_space;

            if (chunk_size > 0) {
                // Get pointer to current slice of data array
                uint8_t *data_payload_ptr = (uint8_t *)destination_buffer + tx_bytes_offset;

                // Write the high-resolution binary chunk to the TCP transmission queue
                err_t err = tcp_write(active_pcb, data_payload_ptr, chunk_size, TCP_WRITE_FLAG_COPY);
                if (err == ERR_OK) {
                    tcp_output(active_pcb); // Push onto physical link immediately
                    tx_bytes_offset += chunk_size;
                }
            }
            */

        case SYS_STREAM_TCP: {
            int remaining_bytes = BYTES_TO_TRANSFER - tx_bytes_offset;

            // As soon as this specific buffer block is cleared out...
            if (remaining_bytes <= 0) {
                // ...instantly flip back to grab the NEXT sequential block from the FPGA wrapper!
                current_state = SYS_START_DMA;
                break;
            }

            int available_tcp_space = tcp_sndbuf(active_pcb);
            int chunk_size = (remaining_bytes < available_tcp_space) ? remaining_bytes : available_tcp_space;

            if (chunk_size > 0) {
                uint8_t *data_payload_ptr = (uint8_t *)destination_buffer + tx_bytes_offset;

                err_t err = tcp_write(active_pcb, data_payload_ptr, chunk_size, TCP_WRITE_FLAG_COPY);
                if (err == ERR_OK) {
                    tcp_output(active_pcb);
                    tx_bytes_offset += chunk_size;
                }
            }
            break;
        }
    }

    return 0;
}

int transfer_data_numbers() {
	if (active_pcb == NULL) {
	        return 0;
	    }

	    /* 2. Track our sequence number (1 to 10) */
	    static int test_counter = 1;

	    /* 3. If we already finished sending 1 to 10, stop completely */
	    if (test_counter > 10) {
	        return 0;
	    }

	    /* 4. Rate Limiting Delay Counter
	          Prevents the Zynq from firing all 10 numbers instantly. */
	    static uint32_t delay_loops = 0;
	    if (delay_loops++ < 10000000) {
	        return 0; // Keep waiting
	    }
	    delay_loops = 0; // Reset delay counter

	    /* 5. Prepare the data packet string */
	    char tx_buffer[16];
	    sprintf(tx_buffer, "%d\n", test_counter);

	    /* 6. Send via lwIP */
	    if (tcp_sndbuf(active_pcb) > strlen(tx_buffer)) {
	        err_t err = tcp_write(active_pcb, tx_buffer, strlen(tx_buffer), TCP_WRITE_FLAG_COPY);

	        if (err == ERR_OK) {
	            tcp_output(active_pcb);  // Force immediate packet transmission
	            xil_printf("Sent test value: %d\r\n", test_counter);
	            test_counter++;          // Move to next number
	        }
	    }

	return 0;
}

